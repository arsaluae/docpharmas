# Lovable Cloud (Supabase) — public client config, safe to ship to the browser.
# These values are auto-generated by Lovable Cloud; do not edit by hand in a Lovable project.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Never put secrets in this file. Service-role keys, AI provider keys, WhatsApp tokens,
# SMTP credentials, and similar belong in the Lovable Cloud > Edge Function Secrets panel.
